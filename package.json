{
  "name": "authz-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Authorization Admin (PAP / IAM core) — multi-tenant access control reference implementation",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint \"packages/**/src/**/*.ts\" \"apps/**/src/**/*.ts\" \"tests/**/src/**/*.ts\"",
    "format": "prettier --write \"packages/**/src/**/*.ts\" \"apps/**/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/src/**/*.ts\" \"apps/**/src/**/*.ts\"",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm -r run test:e2e",
    "test:integration": "pnpm --filter @tests/integration run test:integration",
    "test:playwright": "pnpm --filter @tests/e2e-playwright run test:playwright"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  }
}

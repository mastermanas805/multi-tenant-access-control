# Authorization Admin (PAP) — example environment.
# Copy to .env for local development: `cp .env.example .env`. Never commit a real .env.
#
# When running via `docker compose`, these values are supplied by docker-compose.yml
# (DB_HOST=postgres). For running the app on the host against the compose Postgres,
# keep DB_HOST=localhost.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL (the PAP source of truth — DESIGN §8.3)
DB_HOST=localhost
DB_PORT=5432
# The long-running API connects as the UNPRIVILEGED `authz_app` role
# (NOSUPERUSER NOBYPASSRLS, provisioned by the migration) so Postgres FORCE ROW
# LEVEL SECURITY is actually enforced and tenant isolation can't be bypassed.
# The app fails closed at boot if this role is a superuser or has BYPASSRLS.
#
# The privileged bootstrap superuser (`authz`) is used ONLY for migrations/seed,
# which need DDL and cross-tenant writes. Override these for those commands, e.g.:
#   DB_USERNAME=authz DB_PASSWORD=authz pnpm --filter @app/authz-admin run migration:run
DB_USERNAME=authz_app
DB_PASSWORD=authz_app
DB_DATABASE=authz_admin

# Set true ONLY for local/dev bootstrap. Use migrations in prod.
DB_SYNCHRONIZE=false

# When true, the app connects to Postgres and enables the RLS interceptor.
# When false, the app boots without a DB connection (HTTP-only unit/e2e).
DB_ENABLED=true

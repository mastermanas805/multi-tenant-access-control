{
  "name": "@authz/pep",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable PEP toolkit — AuthzGuard + @Authorize, CerbosPdpClient, PipClient, AuditSink, AuthzModule. Each business service uses this to enforce a Cerbos decision (DESIGN §3.2, §4, §7).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",

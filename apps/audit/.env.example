# Audit Service — example environment.
# Copy to .env for local development. Never commit a real .env.

NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# PostgreSQL (the audit log — its OWN schema, intentionally NOT in the OLTP path
# of other services — DESIGN §8.7 / App. C).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=authz
DB_PASSWORD=authz
DB_DATABASE=audit

# Set true ONLY for local/dev bootstrap. Use migrations in prod.
DB_SYNCHRONIZE=false

# When true, the app connects to Postgres. When false, the app boots without a
# DB connection (useful for unit/e2e of the HTTP layer only).
DB_ENABLED=true

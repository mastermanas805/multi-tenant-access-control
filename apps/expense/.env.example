# Expense Service (PEP) — example environment.
# Copy to .env for local development. Never commit a real .env.

NODE_ENV=development
PORT=3300
LOG_LEVEL=info

# PostgreSQL (the Expense service owns its OWN business data — DESIGN §3.5/§4.3)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=expense_app
DB_PASSWORD=expense_app
DB_DATABASE=expense

# Set true ONLY for local/dev bootstrap. Use migrations in prod.
DB_SYNCHRONIZE=false

# When true, the app connects to Postgres and enables the RLS interceptor.
# When false, the app boots without a DB connection (useful for unit/e2e of HTTP only).
DB_ENABLED=true

# Used only by `pnpm migration:run` to provision the unprivileged app role.
DB_APP_USERNAME=expense_app
DB_APP_PASSWORD=expense_app

# --- PEP wiring (DESIGN §4.4) — where the PDP, PAP and Audit live ---
# Cerbos PDP gRPC endpoint. The PEP's CerbosPdpClient (@cerbos/grpc) connects here.
# In docker-compose this is the co-located Cerbos service: cerbos:3593.
CERBOS_URL=localhost:3593
# PAP base URL — the PIP (HttpPipClient) resolves effective principal roles/attrs
# from GET {PAP_URL}/v1/principals/:id/effective (DESIGN §3.5).
PAP_URL=http://localhost:3000
# Audit service base URL — the AuditSink (HttpAuditSink) posts each decision record
# (allow AND deny) here (DESIGN §8.7).
AUDIT_URL=http://localhost:3100

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node", "jest"],
    // `paths` here REPLACES (not merges) the base-config aliases, so re-declare
    // the full set. Deviation from base: @contracts/core and @authz/pep resolve
    // to their EMITTED declarations rather than their `src` trees. Both packages
    // re-export deep module graphs (contracts' barrel; @authz/pep's NestJS
    // guard/clients) whose source would otherwise be pulled into THIS project's
    // program under `tsc -b` (TS6059/TS6307 rootDir violations). The project
    // references below keep each package compiled by its OWN project; these
    // aliases point TS at that output. @kernel/core keeps the base `src` alias —
    // it redirects cleanly. The jest moduleNameMapper still maps both to `src`
    // (ts-jest single-file transpile has no rootDir program, so src is fine and
    // avoids needing a prior build to run tests).
    "paths": {
      "@kernel": ["../../packages/kernel/src/index.ts"],
      "@kernel/*": ["../../packages/kernel/src/*"],
      "@contracts/core": ["../../packages/contracts/dist/index.d.ts"],
      "@authz/pep": ["../../packages/authz/dist/index.d.ts"],
      "@app/*": ["./src/*"]
    }
  },
  "references": [
    { "path": "../../packages/kernel" },
    { "path": "../../packages/contracts" },
    { "path": "../../packages/authz" }
  ],
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

# Identity Service — example environment.
# Copy to .env for local development. Never commit a real .env.

NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# --- OIDC issuer identity ---
IDENTITY_ISSUER=http://localhost:3100
IDENTITY_AUDIENCE=authz-platform

# --- RS256 signing keypair ---
# Defaults to the COMMITTED DEV keypair under apps/identity/keys/ when unset.
# DEV ONLY — production MUST inject its own keys (file path or inline PEM).
JWT_SIGNING_KID=dev-rsa-2026
# Option A: file paths (recommended in containers / k8s secrets)
# JWT_PRIVATE_KEY_PATH=/run/secrets/identity-private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/identity-public.pem
# Option B: inline PEM (newlines escaped as \n)
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n

# --- Token lifetimes (seconds) ---
ACCESS_TOKEN_TTL_SECONDS=900       # ~15 minutes
REFRESH_TOKEN_TTL_SECONDS=2592000  # ~30 days

# --- Seed users ---
# Defaults to the demo set (riya/sam/dev @acme.com, password "Password123!").
# Override with a JSON array. Plaintext passwords here are a DEV SEED only.
# SEED_USERS=[{"id":"11111111-1111-4111-8111-111111111111","email":"riya@acme.com","password":"Password123!","tenantId":"acme","name":"Riya"}]

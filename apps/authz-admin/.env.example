# Authorization Admin Service — example environment.
# Copy to .env for local development. Never commit a real .env.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL (the PAP source of truth — DESIGN §8.3)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=authz
DB_PASSWORD=authz
DB_DATABASE=authz_admin

# Set true ONLY for local/dev bootstrap. Use migrations in prod.
DB_SYNCHRONIZE=false

# When true, the app connects to Postgres and enables the RLS interceptor.
# When false, the app boots without a DB connection (useful for unit/e2e of HTTP only).
DB_ENABLED=true

# Cerbos PDP publishing (DESIGN §3.4, §8.7, FR-8).
# The shared disk-storage dir the PDP watches (watchForChanges); the PAP compiles
# published policies to Cerbos resourcePolicy YAML and writes them here so a
# runtime, user-defined policy becomes effective in seconds. In docker-compose
# this is the bind-mount ./deploy/cerbos/policies (mounted RW so the PAP can write).
CERBOS_POLICY_DIR=deploy/cerbos/policies
# Set false to disable filesystem publishing (the use-cases become no-ops for the
# Cerbos write); used by tests so they need no disk. Live deployments leave true.
CERBOS_PUBLISH_ENABLED=true
# gRPC endpoint of the Cerbos PDP (for diagnostics/symmetry with the PEP).
CERBOS_URL=localhost:3593

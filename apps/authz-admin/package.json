{
  "name": "@app/authz-admin",
  "version": "0.1.0",
  "private": true,
  "description": "Authorization Admin Service (PAP) — NestJS",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand",
    "typeorm": "typeorm-ts-node-commonjs -d src/shared/infrastructure/database/migration-data-source.ts",
    "migration:run": "pnpm run typeorm migration:run",
    "migration:revert": "pnpm run typeorm migration:revert",
    "migration:show": "pnpm run typeorm migration:show",
    "seed": "node dist/shared/infrastructure/database/seed.js",
    "seed:dev": "ts-node src/shared/infrastructure/database/seed.ts"
  },
  "dependencies": {
    "@kernel/core": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "nestjs-pino": "^4.1.0",
    "pg": "^8.13.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}

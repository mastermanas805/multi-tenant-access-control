# API Gateway — example environment.
# Copy to .env for local development. Never commit a real .env.

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- Inbound user-JWT verification (DESIGN §4.3 step 1, §5) -------------------
# Where to fetch the Identity service's public JWKS for RS256 verification.
IDENTITY_JWKS_URL=http://identity:3200/.well-known/jwks.json
# Expected JWT iss/aud (must match the Identity service's IDENTITY_ISSUER/AUDIENCE).
IDENTITY_ISSUER=http://localhost:3200
IDENTITY_AUDIENCE=authz-platform
# Cache the fetched JWKS for this many seconds (keys rotate slowly).
JWKS_CACHE_TTL_SECONDS=300
# Clock-skew tolerance applied to exp/nbf/iat checks.
JWT_CLOCK_TOLERANCE_SECONDS=60

# --- Outbound signed internal identity token (DESIGN §5, §7) -----------------
# Symmetric key the gateway signs the internal identity token with (HS256). DEV
# DEFAULT — production MUST override with a strong secret (or an asymmetric key).
INTERNAL_TOKEN_SECRET=dev-internal-token-secret-change-me
INTERNAL_TOKEN_KID=gw-internal-2026
INTERNAL_TOKEN_ISSUER=api-gateway
INTERNAL_TOKEN_TTL_SECONDS=120

# --- Upstream routing targets (DESIGN §4.1) ----------------------------------
IDENTITY_URL=http://identity:3200
AUTHZ_ADMIN_URL=http://authz-admin:3000
EXPENSE_URL=http://expense:3300
UPSTREAM_TIMEOUT_MS=10000

# --- Rate limiting (DESIGN §4.4, §10) ----------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
